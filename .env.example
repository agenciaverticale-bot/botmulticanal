# Local / deployment environment variables for botmulticanal
# Copy this file to .env locally or set these values in Render.

# Server configuration
PORT=3000
NODE_ENV=production

# Database / Supabase
DATABASE_URL=postgresql://username:password@host:port/database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_api_key

# Auth / sessions
JWT_SECRET=generate_a_strong_random_secret
VITE_APP_ID=your_manus_app_id
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://manus.im
OWNER_OPEN_ID=your_manus_open_id

# Manus Forge / API proxy
BUILT_IN_FORGE_API_URL=https://api.manus.im
BUILT_IN_FORGE_API_KEY=your_manus_forge_api_key
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im
VITE_FRONTEND_FORGE_API_KEY=your_manus_frontend_forge_api_key

# Webhook verification
WHATSAPP_WEBHOOK_SECRET=your_whatsapp_webhook_secret
WHATSAPP_VERIFY_TOKEN=your_whatsapp_verify_token
INSTAGRAM_APP_SECRET=your_instagram_app_secret
INSTAGRAM_VERIFY_TOKEN=your_instagram_verify_token

# Optional custom API endpoints
EVOLUTION_API_URL=https://api.evolution-api.com/v1
INSTAGRAM_GRAPH_API_URL=https://graph.facebook.com

# Optional external API providers (not currently wired by default)
# Add these if you integrate GROQ / Gemini / Deep Seek in your Render deployment.
GROQ_API_URL=https://your-groq-endpoint
GROQ_API_KEY=your-groq-api-key
VITE_GROQ_API_URL=https://your-groq-endpoint
VITE_GROQ_API_KEY=your-groq-api-key

GEMINI_API_URL=https://your-gemini-endpoint
GEMINI_API_KEY=your-gemini-api-key
VITE_GEMINI_API_KEY=your-gemini-api-key

DEEP_SEEK_API_URL=https://your-deep-seek-endpoint
DEEP_SEEK_API_KEY=your-deep-seek-api-key
VITE_DEEP_SEEK_API_KEY=your-deep-seek-api-key
